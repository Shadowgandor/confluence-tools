{
  "name": "@geeveeh/atlassian-tools",
  "version": "0.4.0",
  "description": "CLI and MCP server for Atlassian Cloud (Confluence, Jira) — manage pages and issues from your terminal or AI agent.",
  "author": "GeeveeH Software",
  "license": "MIT",
  "type": "module",
  "bin": {
    "atlassian": "dist/cli/index.js",
    "atlassian-mcp": "dist/mcp/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/core/index.js",
    "./confluence": "./dist/confluence/index.js",
    "./jira": "./dist/jira/index.js",
    "./mcp": "./dist/mcp/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev:cli": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/index.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "eslint": "^9.20.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
